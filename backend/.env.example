# =============================================================================
# Harper Chat Service — copy to ../.env (repo root) or .env here and edit.
# See docs/CLOUD_SETUP.md for GCP + AWS + DB steps.
# =============================================================================

# --- App / LLM (required for chat) ---
GEMINI_API_KEY=

# --- Database (AlloyDB / Cloud SQL / local Postgres) ---
# Async SQLAlchemy URL; AlloyDB often uses private IP + ssl (see CLOUD_SETUP.md)
HARPER_DATABASE_URL=postgresql+asyncpg://harper_app:CHANGE_ME@127.0.0.1:5432/harper

# --- Redis (optional: sessions / feature cache) ---
# HARPER_REDIS_URL=redis://localhost:6379/0

# --- Local file pipeline (default) ---
# HARPER_PIPELINE_DATA_DIR=.data/pipeline
# HARPER_START_BACKGROUND_WORKERS=true

# =============================================================================
# GCP
# =============================================================================
# HARPER_GCP_PROJECT_ID=my-gcp-project
# HARPER_GCP_REGION=us-central1

# Publish each accepted ingest to Pub/Sub (topic must exist — infra/pubsub.yaml)
# HARPER_PUBSUB_PUBLISH_INGEST=false
# HARPER_PUBSUB_INGEST_TOPIC_ID=ingest-accepted

# Local emulator: gcloud beta emulators pubsub start ...
# PUBSUB_EMULATOR_HOST=127.0.0.1:8085

# Service account JSON (local dev). On Cloud Run use workload identity — leave unset.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json

# Vertex AI Vector Search (Matching Engine) — endpoint resource name / IDs (see CLOUD_SETUP)
# HARPER_ENABLE_VERTEX_VECTOR_UPSERT=false
# HARPER_VERTEX_INDEX_ENDPOINT_ID=
# HARPER_VERTEX_INDEX_ID=
# HARPER_VERTEX_EMBEDDING_MODEL=textembedding-gecko@003

# =============================================================================
# AWS (OpenSearch + S3 raw store)
# =============================================================================
# HARPER_AWS_REGION=us-east-1
# Prefer IAM role on EKS/ECS; locally use env or ~/.aws/credentials
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Raw / archive bucket for ingestion payloads (raw_payload_ref s3://bucket/key)
# HARPER_S3_RAW_BUCKET=my-harper-raw
# Optional bucket root (e.g. prod) — keys still include tenants/{uuid}/... per docs/S3_KEY_LAYOUT.md
# HARPER_S3_RAW_PREFIX=

# OpenSearch (managed: service "es") or Serverless (service "aoss")
# HARPER_ENABLE_OPENSEARCH_INDEX=false
# HARPER_OPENSEARCH_HOST=search-xxxxx.us-east-1.es.amazonaws.com
# HARPER_OPENSEARCH_PORT=443
# HARPER_OPENSEARCH_USE_SSL=true
# HARPER_OPENSEARCH_SERVICE=es
# HARPER_OPENSEARCH_INDEX_NAME=harper-chunks

# =============================================================================
# Auth (JWT Bearer + JWKS) — production: set JWKS URL and validate iss/aud
# =============================================================================
# Leave unset for local dev / tests (no Bearer required on /api/*).
# Works with Auth0, Amazon Cognito, Keycloak, etc.
# HARPER_JWT_JWKS_URL=https://your-tenant.auth0.com/.well-known/jwks.json
# HARPER_JWT_AUDIENCE=https://api.yourproduct.com
# HARPER_JWT_ISSUER=https://your-tenant.auth0.com/
# HARPER_JWT_ALGORITHMS=RS256
# Claim carrying tenant UUID (must match X-Tenant-ID / body tenant when both sent)
# HARPER_JWT_TENANT_CLAIM=tenant_id

# =============================================================================
# Webhooks (HMAC-signed POST /api/webhooks/ingest)
# =============================================================================
# Shared secret; sign body with HMAC-SHA256 hex, header X-Harper-Signature: sha256=<hex>
# HARPER_WEBHOOK_HMAC_SECRET=

# =============================================================================
# Rate limiting (optional; in-process sliding window per IP)
# =============================================================================
# HARPER_RATE_LIMIT_RPM=120

# =============================================================================
# Logging
# =============================================================================
# HARPER_REDACT_SECRETS_IN_LOGS=true

# =============================================================================
# Frontend / CORS
# =============================================================================
# FRONTEND_URL=http://localhost:3000
